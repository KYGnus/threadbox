#!/bin/bash
# Save this as build-deb.sh and run: bash build-deb.sh

set -e
APP_NAME="clamNET"
VERSION="1.0.0"
ARCH="all"

# Create structure
mkdir -p deb_build/DEBIAN
mkdir -p deb_build/opt/${APP_NAME}
mkdir -p deb_build/usr/local/bin

# Create control file
cat > deb_build/DEBIAN/control << EOF
Package: ${APP_NAME}
Version: ${VERSION}
Section: utils
Priority: optional
Architecture: ${ARCH}
Maintainer: Your Name <your.email@example.com>
Description: PulseNET Application
 A Python network monitoring application.
Depends: python3, python3-pip, python3-venv
EOF

# Copy app files
cp -r app deb_build/opt/${APP_NAME}/
cp requirements.txt deb_build/opt/${APP_NAME}/
cp README.md deb_build/opt/${APP_NAME}/

# Create launcher
cat > deb_build/opt/${APP_NAME}/run.sh << 'EOF'
#!/bin/bash
cd /opt/clamNET
if [ ! -d "venv" ]; then
    python3 -m venv venv
    venv/bin/pip install -r requirements.txt
fi
source venv/bin/activate
python3 app/main.py
EOF

chmod +x deb_build/opt/${APP_NAME}/run.sh

# Post-install script
cat > deb_build/DEBIAN/postinst << 'EOF'
#!/bin/bash
ln -sf /opt/clamNET/run.sh /usr/local/bin/clamNET 2>/dev/null || true
echo "Installation complete! Run with: clamNET"
EOF
chmod 755 deb_build/DEBIAN/postinst

# Build package
dpkg-deb --build deb_build ${APP_NAME}_${VERSION}_${ARCH}.deb
rm -rf deb_build

echo "Package created: ${APP_NAME}_${VERSION}_${ARCH}.deb"
